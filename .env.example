# ── Frontend (safe to expose, prefixed with VITE_) ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Backend only (NEVER prefix with VITE_, never commit the real value) ──
